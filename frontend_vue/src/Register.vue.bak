	border-radius: 8px;
	font-size: 16px;
	font-weight: 700;
	background: #d8dce4;
	color: #8f97a8;
	cursor: pointer;
}

.register-btn:disabled {
	cursor: not-allowed;
}

.register-btn:not(:disabled) {
	background: linear-gradient(180deg, #42c8ff, #17a7f6);
	color: #fff;
}

.register-footer {
	margin-top: 16px;
	display: flex;
	justify-content: center;
