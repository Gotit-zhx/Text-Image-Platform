<script setup lang="ts">
import { computed, ref } from 'vue'
import { useRouter } from 'vue-router'

const router = useRouter()

const email = ref('')
const password = ref('')
const confirmPassword = ref('')

const isEmailValid = computed(() => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value))
const isPasswordMatch = computed(
	() => password.value.trim() !== '' && confirmPassword.value.trim() !== '' && password.value === confirmPassword.value
)
const canRegister = computed(() => isEmailValid.value && isPasswordMatch.value)

const goHome = () => {
	router.push('/')
}
</script>

<template>
	<div class="register-page">
		<div class="register-overlay">
			<div class="register-modal" @click.stop>
				<button class="register-close" @click="goHome">×</button>
				<div class="register-brand">miHoYo</div>
				<div class="register-sub-brand">TECH OTAKUS SAVE THE WORLD</div>
				<h3 class="register-title">邮箱注册</h3>

				<input v-model="email" class="register-input" type="email" placeholder="请输入邮箱" />
				<input v-model="password" class="register-input" type="password" placeholder="请输入密码" />
				<input
					v-model="confirmPassword"
					class="register-input"
					type="password"
					placeholder="请确认密码"
				/>

				<p v-if="email && !isEmailValid" class="register-tip">请输入正确的邮箱格式</p>
				<p v-else-if="confirmPassword && !isPasswordMatch" class="register-tip">两次输入的密码不一致</p>

				<button class="register-btn" :disabled="!canRegister">注册</button>

				<div class="register-footer">
					<a href="#" @click.prevent="goHome">返回登录</a>
				</div>
			</div>
		</div>
	</div>
</template>

<style scoped>
