	text-align: center;
	font-size: 42px;
	line-height: 1;
	font-weight: 800;
	letter-spacing: 1px;
	color: #53c4ff;
	margin-top: 4px;
}

.register-sub-brand {
	text-align: center;
	font-size: 9px;
	color: #9dc5df;
	letter-spacing: 1.2px;
	margin-top: 2px;
	margin-bottom: 18px;
}

.register-title {
	margin: 0 0 18px;
	text-align: center;
	font-size: 24px;
	font-weight: 700;
	color: #222c3f;
}

.register-input {
	width: 100%;
	height: 44px;
	border: 1px solid #e3e7ef;
